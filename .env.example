# .env.example — copy to .env and fill in real values
# See docs/agents/system/credentials.md for where to get each credential

# Rails
RAILS_ENV=development
SECRET_KEY_BASE=

# Database
POSTGRES_USERNAME=postgres
POSTGRES_PASSWORD=

# Sportradar (https://developer.sportradar.com)
SPORTRADAR_API_KEY=
SPORTRADAR_ACCESS_LEVEL=trial
SPORTRADAR_BASE_URL=https://api.sportradar.com/nfl/official

# External services (no key needed)
SPORTSODDSHISTORY_BASE_URL=https://www.sportsoddshistory.com
PFF_BASE_URL=https://www.pff.com

# Redis (production only)
REDIS_URL=redis://localhost:6379/1

# Rails thread config
RAILS_MAX_THREADS=5
