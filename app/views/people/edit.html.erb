<div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
  <div class="bg-gradient-to-r from-teal-600 to-cyan-600 rounded-t-xl p-6 shadow-lg">
    <h1 class="text-2xl font-bold text-white">Edit Person</h1>
    <p class="text-teal-100 text-sm mt-1"><%= @person.first_name %> <%= @person.last_name %></p>
  </div>

  <div class="theme-bg-primary shadow-lg rounded-b-xl p-6 border border-t-0 theme-border-primary">
    <%= render "form", person: @person %>
  </div>
</div>
