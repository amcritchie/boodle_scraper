<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
  <!-- Header -->
  <div class="bg-gradient-to-r from-teal-600 to-cyan-600 rounded-t-xl p-6 shadow-lg">
    <div class="flex justify-between items-center">
      <div>
        <h1 class="text-2xl font-bold text-white">People</h1>
        <p class="text-teal-100 text-sm mt-1"><%= @people.count %> people</p>
      </div>
      <a href="<%= new_person_path %>" class="bg-white text-teal-600 hover:bg-teal-50 px-4 py-2 rounded-lg text-sm font-semibold transition-colors shadow">
        + New Person
      </a>
    </div>
  </div>

  <% if flash[:notice] %>
    <div class="bg-green-100 dark:bg-green-900 border border-green-400 dark:border-green-700 text-green-700 dark:text-green-200 px-4 py-3 rounded-b-none" role="alert">
      <%= flash[:notice] %>
    </div>
  <% end %>

  <!-- Table -->
  <div class="theme-bg-primary shadow-lg rounded-b-xl overflow-hidden border theme-border-primary">
    <div class="overflow-x-auto">
      <table class="min-w-full divide-y theme-border-primary">
        <thead class="theme-bg-tertiary">
          <tr>
            <th class="px-4 py-3 text-left text-xs font-medium theme-text-secondary uppercase tracking-wider">First Name</th>
            <th class="px-4 py-3 text-left text-xs font-medium theme-text-secondary uppercase tracking-wider">Last Name</th>
            <th class="px-4 py-3 text-left text-xs font-medium theme-text-secondary uppercase tracking-wider">Slug</th>
            <th class="px-4 py-3 text-left text-xs font-medium theme-text-secondary uppercase tracking-wider">Player Slug</th>
            <th class="px-4 py-3 text-left text-xs font-medium theme-text-secondary uppercase tracking-wider">Birthday</th>
            <th class="px-4 py-3 text-left text-xs font-medium theme-text-secondary uppercase tracking-wider">Twitter</th>
            <th class="px-4 py-3 text-right text-xs font-medium theme-text-secondary uppercase tracking-wider">Actions</th>
          </tr>
        </thead>
        <tbody class="divide-y theme-border-primary">
          <% @people.each do |person| %>
            <tr class="hover:theme-bg-tertiary transition-colors">
              <td class="px-4 py-3 text-sm theme-text-primary font-medium"><%= person.first_name %></td>
              <td class="px-4 py-3 text-sm theme-text-primary font-medium"><%= person.last_name %></td>
              <td class="px-4 py-3 text-sm theme-text-secondary font-mono"><%= person.slug %></td>
              <td class="px-4 py-3 text-sm theme-text-secondary font-mono"><%= person.player_slug %></td>
              <td class="px-4 py-3 text-sm theme-text-secondary"><%= person.birthday&.strftime("%b %d, %Y") %></td>
              <td class="px-4 py-3 text-sm theme-text-secondary"><%= person.twitter_account %></td>
              <td class="px-4 py-3 text-right text-sm whitespace-nowrap">
                <a href="<%= edit_person_path(person) %>" class="text-teal-600 dark:text-teal-400 hover:text-teal-900 dark:hover:text-teal-300 font-medium mr-3">Edit</a>
                <%= button_to "Delete", person_path(person), method: :delete, data: { turbo_confirm: "Are you sure you want to delete this person?" }, class: "text-red-600 dark:text-red-400 hover:text-red-900 dark:hover:text-red-300 font-medium", form: { class: "inline" } %>
              </td>
            </tr>
          <% end %>

          <% if @people.empty? %>
            <tr>
              <td colspan="7" class="px-4 py-8 text-center theme-text-secondary text-sm">
                No people yet. <a href="<%= new_person_path %>" class="text-teal-600 dark:text-teal-400 hover:underline">Create one</a>.
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>
</div>
