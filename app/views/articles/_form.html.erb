<%= form_with(model: article, local: true, class: "space-y-6") do |f| %>
  <% if article.errors.any? %>
    <div class="bg-red-100 dark:bg-red-900 border border-red-400 dark:border-red-700 text-red-700 dark:text-red-200 px-4 py-3 rounded">
      <h3 class="font-medium"><%= pluralize(article.errors.count, "error") %> prohibited this article from being saved:</h3>
      <ul class="mt-2 list-disc list-inside text-sm">
        <% article.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
    <!-- Title -->
    <div class="md:col-span-2">
      <%= f.label :title, class: "block text-sm font-medium theme-text-primary mb-1" %>
      <%= f.text_field :title, class: "w-full rounded-lg border theme-border-primary theme-bg-primary theme-text-primary px-3 py-2 text-sm focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500" %>
    </div>

    <!-- Title Summary -->
    <div class="md:col-span-2">
      <%= f.label :title_summary, "Title Summary", class: "block text-sm font-medium theme-text-primary mb-1" %>
      <%= f.text_field :title_summary, class: "w-full rounded-lg border theme-border-primary theme-bg-primary theme-text-primary px-3 py-2 text-sm focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500" %>
    </div>

    <!-- Author -->
    <div>
      <%= f.label :author, class: "block text-sm font-medium theme-text-primary mb-1" %>
      <%= f.text_field :author, class: "w-full rounded-lg border theme-border-primary theme-bg-primary theme-text-primary px-3 py-2 text-sm focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500" %>
    </div>

    <!-- Sport -->
    <div>
      <%= f.label :sport, class: "block text-sm font-medium theme-text-primary mb-1" %>
      <%= f.text_field :sport, class: "w-full rounded-lg border theme-border-primary theme-bg-primary theme-text-primary px-3 py-2 text-sm focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500" %>
    </div>

    <!-- Published At -->
    <div>
      <%= f.label :published_at, "Published At", class: "block text-sm font-medium theme-text-primary mb-1" %>
      <%= f.date_field :published_at, class: "w-full rounded-lg border theme-border-primary theme-bg-primary theme-text-primary px-3 py-2 text-sm focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500" %>
    </div>

    <!-- Reviewed At -->
    <div>
      <%= f.label :reviewed_at, "Reviewed At", class: "block text-sm font-medium theme-text-primary mb-1" %>
      <%= f.datetime_local_field :reviewed_at, class: "w-full rounded-lg border theme-border-primary theme-bg-primary theme-text-primary px-3 py-2 text-sm focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500" %>
    </div>

    <!-- Main Team Name -->
    <div>
      <%= f.label :main_team_name, "Main Team Name", class: "block text-sm font-medium theme-text-primary mb-1" %>
      <%= f.text_field :main_team_name, class: "w-full rounded-lg border theme-border-primary theme-bg-primary theme-text-primary px-3 py-2 text-sm focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500" %>
    </div>

    <!-- Main Team Slug -->
    <div>
      <%= f.label :main_team_slug, "Main Team Slug", class: "block text-sm font-medium theme-text-primary mb-1" %>
      <%= f.text_field :main_team_slug, class: "w-full rounded-lg border theme-border-primary theme-bg-primary theme-text-primary px-3 py-2 text-sm focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500" %>
    </div>

    <!-- Main Person Name -->
    <div>
      <%= f.label :main_person_name, "Main Person Name", class: "block text-sm font-medium theme-text-primary mb-1" %>
      <%= f.text_field :main_person_name, class: "w-full rounded-lg border theme-border-primary theme-bg-primary theme-text-primary px-3 py-2 text-sm focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500" %>
    </div>

    <!-- Main Person Slug -->
    <div>
      <%= f.label :main_person_slug, "Main Person Slug", class: "block text-sm font-medium theme-text-primary mb-1" %>
      <%= f.text_field :main_person_slug, class: "w-full rounded-lg border theme-border-primary theme-bg-primary theme-text-primary px-3 py-2 text-sm focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500" %>
    </div>

    <!-- Source -->
    <div>
      <%= f.label :source, class: "block text-sm font-medium theme-text-primary mb-1" %>
      <%= f.text_field :source, class: "w-full rounded-lg border theme-border-primary theme-bg-primary theme-text-primary px-3 py-2 text-sm focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500" %>
    </div>

    <!-- Source URL -->
    <div>
      <%= f.label :source_url, "Source URL", class: "block text-sm font-medium theme-text-primary mb-1" %>
      <%= f.url_field :source_url, class: "w-full rounded-lg border theme-border-primary theme-bg-primary theme-text-primary px-3 py-2 text-sm focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500" %>
    </div>

    <!-- Source ID -->
    <div>
      <%= f.label :source_id, "Source ID", class: "block text-sm font-medium theme-text-primary mb-1" %>
      <%= f.text_field :source_id, class: "w-full rounded-lg border theme-border-primary theme-bg-primary theme-text-primary px-3 py-2 text-sm focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500" %>
    </div>

    <!-- Model -->
    <div>
      <%= f.label :model, class: "block text-sm font-medium theme-text-primary mb-1" %>
      <%= f.text_field :model, class: "w-full rounded-lg border theme-border-primary theme-bg-primary theme-text-primary px-3 py-2 text-sm focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500" %>
    </div>

    <!-- Process -->
    <div>
      <%= f.label :process, class: "block text-sm font-medium theme-text-primary mb-1" %>
      <%= f.text_field :process, class: "w-full rounded-lg border theme-border-primary theme-bg-primary theme-text-primary px-3 py-2 text-sm focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500" %>
    </div>

    <!-- Process Notes -->
    <div class="md:col-span-2">
      <%= f.label :process_notes, "Process Notes", class: "block text-sm font-medium theme-text-primary mb-1" %>
      <%= f.text_area :process_notes, rows: 3, class: "w-full rounded-lg border theme-border-primary theme-bg-primary theme-text-primary px-3 py-2 text-sm focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500" %>
    </div>

    <!-- Context -->
    <div class="md:col-span-2">
      <%= f.label :context, class: "block text-sm font-medium theme-text-primary mb-1" %>
      <%= f.text_area :context, rows: 4, class: "w-full rounded-lg border theme-border-primary theme-bg-primary theme-text-primary px-3 py-2 text-sm focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500" %>
    </div>

    <!-- Teams JSON -->
    <div class="md:col-span-2">
      <%= f.label :teams_json, "Teams (JSON)", class: "block text-sm font-medium theme-text-primary mb-1" %>
      <%= f.text_area :teams_json, value: article.teams_json.present? ? JSON.pretty_generate(article.teams_json) : "", rows: 3, class: "w-full rounded-lg border theme-border-primary theme-bg-primary theme-text-primary px-3 py-2 text-sm font-mono focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500" %>
      <p class="mt-1 text-xs theme-text-secondary">Enter valid JSON array of team objects</p>
    </div>

    <!-- People JSON -->
    <div class="md:col-span-2">
      <%= f.label :people_json, "People (JSON)", class: "block text-sm font-medium theme-text-primary mb-1" %>
      <%= f.text_area :people_json, value: article.people_json.present? ? JSON.pretty_generate(article.people_json) : "", rows: 3, class: "w-full rounded-lg border theme-border-primary theme-bg-primary theme-text-primary px-3 py-2 text-sm font-mono focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500" %>
      <p class="mt-1 text-xs theme-text-secondary">Enter valid JSON array of people objects</p>
    </div>

    <!-- Scores JSON -->
    <div class="md:col-span-2">
      <%= f.label :scores_json, "Scores (JSON)", class: "block text-sm font-medium theme-text-primary mb-1" %>
      <%= f.text_area :scores_json, value: article.scores_json.present? ? JSON.pretty_generate(article.scores_json) : "", rows: 3, class: "w-full rounded-lg border theme-border-primary theme-bg-primary theme-text-primary px-3 py-2 text-sm font-mono focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500" %>
    </div>

    <!-- Records JSON -->
    <div class="md:col-span-2">
      <%= f.label :records_json, "Records (JSON)", class: "block text-sm font-medium theme-text-primary mb-1" %>
      <%= f.text_area :records_json, value: article.records_json.present? ? JSON.pretty_generate(article.records_json) : "", rows: 3, class: "w-full rounded-lg border theme-border-primary theme-bg-primary theme-text-primary px-3 py-2 text-sm font-mono focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500" %>
    </div>

    <!-- Key Stats JSON -->
    <div class="md:col-span-2">
      <%= f.label :key_stats_json, "Key Stats (JSON)", class: "block text-sm font-medium theme-text-primary mb-1" %>
      <%= f.text_area :key_stats_json, value: article.key_stats_json.present? ? JSON.pretty_generate(article.key_stats_json) : "", rows: 3, class: "w-full rounded-lg border theme-border-primary theme-bg-primary theme-text-primary px-3 py-2 text-sm font-mono focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500" %>
    </div>

    <!-- Quotes JSON -->
    <div class="md:col-span-2">
      <%= f.label :quotes_json, "Quotes (JSON)", class: "block text-sm font-medium theme-text-primary mb-1" %>
      <%= f.text_area :quotes_json, value: article.quotes_json.present? ? JSON.pretty_generate(article.quotes_json) : "", rows: 3, class: "w-full rounded-lg border theme-border-primary theme-bg-primary theme-text-primary px-3 py-2 text-sm font-mono focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500" %>
    </div>

    <!-- Feedback -->
    <div class="md:col-span-2">
      <%= f.label :feedback, class: "block text-sm font-medium theme-text-primary mb-1" %>
      <%= f.text_area :feedback, rows: 3, class: "w-full rounded-lg border theme-border-primary theme-bg-primary theme-text-primary px-3 py-2 text-sm focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500" %>
    </div>

    <!-- Checkboxes -->
    <div class="md:col-span-2 flex flex-wrap gap-6">
      <label class="flex items-center space-x-2">
        <%= f.check_box :article_good, class: "rounded border-gray-300 text-indigo-600 focus:ring-indigo-500 h-4 w-4" %>
        <span class="text-sm font-medium theme-text-primary">Article Good</span>
      </label>

      <label class="flex items-center space-x-2">
        <%= f.check_box :person_identified, class: "rounded border-gray-300 text-indigo-600 focus:ring-indigo-500 h-4 w-4" %>
        <span class="text-sm font-medium theme-text-primary">Person Identified</span>
      </label>

      <label class="flex items-center space-x-2">
        <%= f.check_box :disposition_coherent, class: "rounded border-gray-300 text-indigo-600 focus:ring-indigo-500 h-4 w-4" %>
        <span class="text-sm font-medium theme-text-primary">Disposition Coherent</span>
      </label>
    </div>
  </div>

  <!-- Submit -->
  <div class="flex items-center space-x-4 pt-4">
    <%= f.submit class: "bg-indigo-600 hover:bg-indigo-700 text-white px-6 py-2 rounded-lg text-sm font-semibold transition-colors shadow cursor-pointer" %>
    <a href="<%= articles_path %>" class="theme-text-secondary hover:theme-text-primary text-sm font-medium">Cancel</a>
  </div>
<% end %>
