<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
  <!-- Header -->
  <div class="bg-gradient-to-r from-indigo-600 to-purple-600 rounded-xl p-6 shadow-lg mb-6">
    <div class="flex justify-between items-center">
      <div>
        <h1 class="text-2xl font-bold text-white">Articles</h1>
        <p class="text-indigo-100 text-sm mt-1"><%= @articles.count %> articles</p>
      </div>
      <a href="<%= new_article_path %>" class="bg-white text-indigo-600 hover:bg-indigo-50 px-4 py-2 rounded-lg text-sm font-semibold transition-colors shadow">
        + New Article
      </a>
    </div>
  </div>

  <% if flash[:notice] %>
    <div class="bg-green-100 dark:bg-green-900 border border-green-400 dark:border-green-700 text-green-700 dark:text-green-200 px-4 py-3 rounded-lg mb-6" role="alert">
      <%= flash[:notice] %>
    </div>
  <% end %>

  <!-- Article Cards -->
  <div class="space-y-4">
    <% @articles.each do |article| %>
      <div class="theme-bg-primary shadow-lg rounded-xl border theme-border-primary p-5">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">

          <!-- Left Column: Title, Author, Dates, Names -->
          <div>
            <h2 class="text-lg font-bold theme-text-primary"><%= article.title %></h2>
            <p class="text-sm theme-text-secondary mt-1"><%= article.author %></p>
            <p class="text-sm theme-text-secondary mt-2">Published: <span class="theme-text-primary"><%= article.published_at&.strftime("%b %d, %Y") || "—" %></span></p>
            <p class="text-sm theme-text-secondary">Reviewed: <span class="theme-text-primary"><%= article.reviewed_at&.strftime("%b %d, %Y %l:%M %p") || "—" %></span></p>
            <% if article.source.present? || article.source_url.present? %>
              <p class="text-sm theme-text-secondary mt-2">Source:
                <% if article.source_url.present? %>
                  <a href="<%= article.source_url %>" target="_blank" class="text-indigo-600 dark:text-indigo-400 hover:underline"><%= article.source.presence || article.source_url %></a>
                <% else %>
                  <span class="theme-text-primary"><%= article.source %></span>
                <% end %>
              </p>
            <% end %>

            <% if article.names.present? %>
              <p class="text-sm font-medium theme-text-secondary mt-3">Names</p>
              <div class="flex flex-wrap gap-2 mt-1">
                <% Array(article.names).each do |name| %>
                  <span class="inline-block px-3 py-1 text-sm rounded-full bg-green-100 text-green-800 dark:bg-green-900 dark:text-green-200"><%= name %></span>
                <% end %>
              </div>
            <% end %>
          </div>

          <!-- Middle Column: Athlete Info, Disposition -->
          <div>
            <p class="text-sm font-medium theme-text-secondary">Primary Athlete Name</p>
            <p class="text-sm theme-text-primary mb-3"><%= article.main_person_name.presence || "—" %></p>

            <p class="text-sm font-medium theme-text-secondary">Primary Athlete Slug</p>
            <p class="text-sm theme-text-primary mb-3"><%= article.person_slug.presence || "—" %></p>

            <p class="text-sm font-medium theme-text-secondary">Article Disposition</p>
            <p class="text-sm theme-text-primary"><%= article.disposition.presence || "—" %></p>
          </div>

          <!-- Right Column: Edit Button -->
          <div class="flex flex-col items-end space-y-2">
            <a href="<%= edit_article_path(article) %>" class="inline-flex items-center px-4 py-2 border theme-border-primary rounded-lg text-sm font-medium theme-text-primary hover:theme-bg-tertiary transition-colors">
              Edit / Feedback
              <svg class="ml-2 h-4 w-4 theme-text-secondary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.066 2.573c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.573 1.066c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.066-2.573c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"></path>
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path>
              </svg>
            </a>
            <a href="#" class="inline-flex items-center px-4 py-2 bg-indigo-600 hover:bg-indigo-700 text-white rounded-lg text-sm font-medium transition-colors shadow">
              Write Post
              <svg class="ml-2 h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path>
              </svg>
            </a>
          </div>
        </div>

        <!-- Feedback Row -->
        <div class="flex flex-wrap items-center gap-6 mt-4 pt-4 border-t theme-border-primary">
          <!-- Article Interesting -->
          <div class="flex items-center gap-2">
            <p class="text-sm font-medium theme-text-secondary">Article Interesting</p>
            <div class="inline-flex rounded-lg border theme-border-primary overflow-hidden">
              <%= button_to feedback_article_path(article), method: :patch, params: { field: "article_good", value: "false" }, class: "px-3 py-0.5 text-sm leading-tight transition-colors #{article.article_good == false ? 'bg-red-100 dark:bg-red-900' : 'hover:theme-bg-tertiary'}", form: { class: "inline" } do %>
                👎
              <% end %>
              <%= button_to feedback_article_path(article), method: :patch, params: { field: "article_good", value: "true" }, class: "px-3 py-0.5 text-sm leading-tight border-l theme-border-primary transition-colors #{article.article_good == true ? 'bg-green-100 dark:bg-green-900' : 'hover:theme-bg-tertiary'}", form: { class: "inline" } do %>
                👍
              <% end %>
            </div>
          </div>

          <!-- Athlete Identified -->
          <div class="flex items-center gap-2">
            <p class="text-sm font-medium theme-text-secondary">Athlete Identified</p>
            <div class="inline-flex rounded-lg border theme-border-primary overflow-hidden">
              <%= button_to feedback_article_path(article), method: :patch, params: { field: "person_identified", value: "false" }, class: "px-3 py-0.5 text-sm leading-tight transition-colors #{article.person_identified == false ? 'bg-red-100 dark:bg-red-900' : 'hover:theme-bg-tertiary'}", form: { class: "inline" } do %>
                👎
              <% end %>
              <%= button_to feedback_article_path(article), method: :patch, params: { field: "person_identified", value: "true" }, class: "px-3 py-0.5 text-sm leading-tight border-l theme-border-primary transition-colors #{article.person_identified == true ? 'bg-green-100 dark:bg-green-900' : 'hover:theme-bg-tertiary'}", form: { class: "inline" } do %>
                👍
              <% end %>
            </div>
          </div>

          <!-- Disposition Coherent -->
          <div class="flex items-center gap-2">
            <p class="text-sm font-medium theme-text-secondary">Disposition Coherent</p>
            <div class="inline-flex rounded-lg border theme-border-primary overflow-hidden">
              <%= button_to feedback_article_path(article), method: :patch, params: { field: "disposition_coherent", value: "false" }, class: "px-3 py-0.5 text-sm leading-tight transition-colors #{article.disposition_coherent == false ? 'bg-red-100 dark:bg-red-900' : 'hover:theme-bg-tertiary'}", form: { class: "inline" } do %>
                👎
              <% end %>
              <%= button_to feedback_article_path(article), method: :patch, params: { field: "disposition_coherent", value: "true" }, class: "px-3 py-0.5 text-sm leading-tight border-l theme-border-primary transition-colors #{article.disposition_coherent == true ? 'bg-green-100 dark:bg-green-900' : 'hover:theme-bg-tertiary'}", form: { class: "inline" } do %>
                👍
              <% end %>
            </div>
          </div>
        </div>
      </div>
    <% end %>

    <% if @articles.empty? %>
      <div class="theme-bg-primary shadow-lg rounded-xl border theme-border-primary p-8 text-center">
        <p class="theme-text-secondary text-sm">No articles yet. <a href="<%= new_article_path %>" class="text-indigo-600 dark:text-indigo-400 hover:underline">Create one</a>.</p>
      </div>
    <% end %>
  </div>
</div>
