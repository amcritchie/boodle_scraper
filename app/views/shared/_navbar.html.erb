<!-- Universal Navbar with Theme System -->
<header class="fixed top-0 left-0 right-0 z-50 theme-bg-primary shadow-sm border-b theme-border-primary transition-all duration-300"
        x-data="{ scrolled: false }"
        x-init="window.addEventListener('scroll', () => { scrolled = window.scrollY > 10 })"
        :class="scrolled ? 'py-1' : 'py-4'">
  
  <%= render 'shared/environment_banner' %>
  
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex justify-between items-center">
      <div class="flex items-center space-x-6">
        <a href="/" class="flex items-center space-x-6 hover:opacity-80 transition-opacity">
          <div class="flex flex-col sm:flex-row sm:items-center sm:space-x-6">
            <div class="flex items-center space-x-3 sm:space-x-6">
              <%= image_tag("turf-monster-icon.png", { alt: "Turf Monster Logo", class: "h-8 w-auto" }) %>
              <span class="text-2xl font-bold theme-text-primary sm:hidden">Turf</span>
            </div>
            <h1 class="text-2xl font-bold theme-text-primary sm:hidden -mt-1">Monster</h1>
            <h1 class="hidden sm:block text-2xl font-bold theme-text-primary">Turf Monster</h1>
          </div>
        </a>
      </div>
      <div class="flex items-center space-x-4">
        <nav class="flex space-x-0 items-center">

          <% games_active = controller_name.in?(%w[predictions games]) %>
          <a href="<%= predictions_week_path(2025, 1) %>" class="<%= games_active ? 'text-emerald-600 dark:text-emerald-400 bg-emerald-50 dark:bg-emerald-900/30' : 'theme-text-secondary' %> hover:theme-text-primary px-3 py-2 rounded-md text-sm font-medium transition-colors">
            Games
          </a>
          <% news_active = controller_name == 'news' %>
          <a href="<%= news_index_path %>" class="<%= news_active ? 'text-emerald-600 dark:text-emerald-400 bg-emerald-50 dark:bg-emerald-900/30' : 'theme-text-secondary' %> hover:theme-text-primary px-3 py-2 rounded-md text-sm font-medium transition-colors">
            News
          </a>
          <% memes_active = controller_name == 'memes' %>
          <a href="<%= memes_path %>" class="<%= memes_active ? 'text-emerald-600 dark:text-emerald-400 bg-emerald-50 dark:bg-emerald-900/30' : 'theme-text-secondary' %> hover:theme-text-primary px-3 py-2 rounded-md text-sm font-medium transition-colors">
            Memes
          </a>
          <% content_active = controller_name == 'contents' %>
          <a href="<%= contents_path %>" class="<%= content_active ? 'text-emerald-600 dark:text-emerald-400 bg-emerald-50 dark:bg-emerald-900/30' : 'theme-text-secondary' %> hover:theme-text-primary px-3 py-2 rounded-md text-sm font-medium transition-colors">
            Content
          </a>
          <% unless Rails.env.production? %>
            <% agents_active = controller_name == 'agents_dashboard' %>
            <a href="<%= agents_dashboard_path %>" class="<%= agents_active ? 'text-emerald-600 dark:text-emerald-400 bg-emerald-50 dark:bg-emerald-900/30' : 'theme-text-secondary' %> hover:theme-text-primary px-3 py-2 rounded-md text-sm font-medium transition-colors">
              Agents
            </a>
          <% end %>

          <!-- Admin Dropdown -->
          <% admin_controllers = %w[articles people posts rankings players matchups teams] %>
          <% admin_active = controller_name.in?(admin_controllers) %>
          <div class="relative" x-data="{ open: false }">
            <button @click="open = !open"
                    class="<%= admin_active ? 'text-emerald-600 dark:text-emerald-400 bg-emerald-50 dark:bg-emerald-900/30' : 'theme-text-secondary' %> hover:theme-text-primary px-3 py-2 rounded-md text-sm font-medium transition-colors flex items-center">
              Admin
              <svg class="ml-1 h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
              </svg>
            </button>

            <div x-show="open"
                 @click.away="open = false"
                 x-transition:enter="transition ease-out duration-100"
                 x-transition:enter-start="transform opacity-0 scale-95"
                 x-transition:enter-end="transform opacity-100 scale-100"
                 x-transition:leave="transition ease-in duration-75"
                 x-transition:leave-start="transform opacity-100 scale-100"
                 x-transition:leave-end="transform opacity-0 scale-95"
                 class="absolute right-0 mt-2 w-48 theme-bg-primary rounded-md shadow-lg py-1 z-50 border theme-border-primary">

              <a href="https://414hyu.share-na2.hsforms.com/2OI-xECHNSn-BhXAI8fuhwQ" target="_blank" class="block px-4 py-2 text-sm text-orange-500 font-semibold hover:theme-bg-tertiary">
                Picks
              </a>
              <a href="<%= articles_path %>" class="block px-4 py-2 text-sm hover:theme-bg-tertiary <%= controller_name == 'articles' ? 'text-emerald-600 dark:text-emerald-400 font-semibold' : 'theme-text-secondary hover:theme-text-primary' %>">
                Articles
              </a>
              <a href="<%= people_path %>" class="block px-4 py-2 text-sm hover:theme-bg-tertiary <%= controller_name == 'people' ? 'text-emerald-600 dark:text-emerald-400 font-semibold' : 'theme-text-secondary hover:theme-text-primary' %>">
                People
              </a>
              <a href="<%= posts_path %>" class="block px-4 py-2 text-sm hover:theme-bg-tertiary <%= controller_name == 'posts' ? 'text-emerald-600 dark:text-emerald-400 font-semibold' : 'theme-text-secondary hover:theme-text-primary' %>">
                Posts
              </a>
              <a href="/nfl-quarterback-rankings" class="block px-4 py-2 text-sm hover:theme-bg-tertiary <%= controller_name == 'rankings' ? 'text-emerald-600 dark:text-emerald-400 font-semibold' : 'theme-text-secondary hover:theme-text-primary' %>">
                QB Rankings
              </a>

              <% unless Rails.env.production? %>
                <div class="border-t theme-border-primary my-1"></div>
                <a href="<%= all_games_path %>" class="block px-4 py-2 text-sm hover:theme-bg-tertiary <%= controller_name == 'games' ? 'text-emerald-600 dark:text-emerald-400 font-semibold' : 'theme-text-secondary hover:theme-text-primary' %>">
                  All Games
                </a>
                <a href="<%= games_week1_path(2025) %>" class="block px-4 py-2 text-sm hover:theme-bg-tertiary <%= controller_name == 'predictions' ? 'text-emerald-600 dark:text-emerald-400 font-semibold' : 'theme-text-secondary hover:theme-text-primary' %>">
                  Week 1
                </a>
                <a href="/matchups" class="block px-4 py-2 text-sm hover:theme-bg-tertiary <%= controller_name == 'matchups' ? 'text-emerald-600 dark:text-emerald-400 font-semibold' : 'theme-text-secondary hover:theme-text-primary' %>">
                  Matchups
                </a>
                <a href="<%= matchups_summary_path(2025) %>" class="block px-4 py-2 text-sm hover:theme-bg-tertiary theme-text-secondary hover:theme-text-primary">
                  Matchup Summary
                </a>
                <a href="<%= teams_power_rankings_path(2025) %>" class="block px-4 py-2 text-sm hover:theme-bg-tertiary <%= controller_name == 'teams' ? 'text-emerald-600 dark:text-emerald-400 font-semibold' : 'theme-text-secondary hover:theme-text-primary' %>">
                  Power Rankings
                </a>
                <a href="<%= teams_rankings_path(2025) %>" class="block px-4 py-2 text-sm hover:theme-bg-tertiary theme-text-secondary hover:theme-text-primary">
                  All Rankings
                </a>
                <a href="<%= players_index_path %>" class="block px-4 py-2 text-sm hover:theme-bg-tertiary <%= controller_name == 'players' ? 'text-emerald-600 dark:text-emerald-400 font-semibold' : 'theme-text-secondary hover:theme-text-primary' %>">
                  All Players
                </a>
                <a href="<%= nfl_offensive_line_rankings_path %>" class="block px-4 py-2 text-sm hover:theme-bg-tertiary theme-text-secondary hover:theme-text-primary">
                  O-Line Rankings
                </a>
                <a href="/tb/atl/1/2025" class="block px-4 py-2 text-sm hover:theme-bg-tertiary theme-text-secondary hover:theme-text-primary">
                  🏴‍☠️🐦‍🔥
                </a>
              <% end %>

            </div>
          </div>

        </nav>
        <!-- Theme Toggle -->
        <button data-action="click->theme#toggle"
                data-theme-target="toggle"
                class="p-2 rounded-lg theme-bg-accent hover:theme-bg-tertiary transition-colors">
          <!-- Moon icon (shown when in light mode) -->
          <svg data-theme-target="icon" data-theme-value="light" class="w-5 h-5 theme-text-secondary" fill="currentColor" viewBox="0 0 20 20">
            <path d="M17.293 13.293A8 8 0 016.707 2.707a8.001 8.001 0 1010.586 10.586z"/>
          </svg>
          <!-- Sun icon (shown when in dark mode) -->
          <svg data-theme-target="icon" data-theme-value="dark" class="w-5 h-5 text-yellow-300" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M10 2a1 1 0 011 1v1a1 1 0 11-2 0V3a1 1 0 011-1zm4 8a4 4 0 11-8 0 4 4 0 018 0zm-.464 4.95l.707.707a1 1 0 001.414-1.414l-.707-.707a1 1 0 00-1.414 1.414zM17 11a1 1 0 100-2h-1a1 1 0 100 2h1zm-7 4a1 1 0 011 1v1a1 1 0 11-2 0v-1a1 1 0 011-1zM5.05 6.464A1 1 0 106.465 5.05l-.708-.707a1 1 0 00-1.414 1.414l.707.707zm1.414 8.486l-.707.707a1 1 0 01-1.414-1.414l.707-.707a1 1 0 011.414 1.414zM4 11a1 1 0 100-2H3a1 1 0 000 2h1z" clip-rule="evenodd"/>
          </svg>
        </button>
      </div>
    </div>
  </div>
</header>

<!-- Spacer to prevent content from being hidden behind fixed navbar -->
<!-- Height accounts for navbar + environment banner in development -->
<div class="<%= Rails.env.production? ? 'h-24' : 'h-28' %>"></div>