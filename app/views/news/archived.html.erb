<div class="max-w-full mx-auto px-4 sm:px-6 lg:px-8 py-8">
  <div class="bg-gradient-to-r from-gray-600 to-gray-700 rounded-t-xl p-6 shadow-lg">
    <div class="flex justify-between items-center">
      <div>
        <h1 class="text-2xl font-bold text-white">Archived News</h1>
        <p class="text-gray-300 text-sm mt-1"><%= @archived_news.count %> items</p>
      </div>
      <a href="<%= news_index_path %>" class="bg-white text-gray-600 hover:bg-gray-50 px-4 py-2 rounded-lg text-sm font-semibold transition-colors shadow">
        Back to Board
      </a>
    </div>
  </div>

  <% if flash[:notice] %>
    <div class="bg-green-100 dark:bg-green-900 border border-green-400 dark:border-green-700 text-green-700 dark:text-green-200 px-4 py-3" role="alert">
      <%= flash[:notice] %>
    </div>
  <% end %>

  <div class="theme-bg-primary shadow-lg rounded-b-xl border border-t-0 theme-border-primary overflow-hidden">
    <% if @archived_news.any? %>
      <table class="w-full">
        <thead>
          <tr class="theme-bg-tertiary">
            <th class="text-left px-4 py-3 text-xs font-medium theme-text-secondary uppercase">Title</th>
            <th class="text-left px-4 py-3 text-xs font-medium theme-text-secondary uppercase">Person / Team</th>
            <th class="text-left px-4 py-3 text-xs font-medium theme-text-secondary uppercase">Author</th>
            <th class="text-left px-4 py-3 text-xs font-medium theme-text-secondary uppercase">Published</th>
            <th class="text-right px-4 py-3 text-xs font-medium theme-text-secondary uppercase">Actions</th>
          </tr>
        </thead>
        <tbody class="divide-y theme-border-primary">
          <% @archived_news.each do |news| %>
            <tr class="hover:theme-bg-tertiary transition-colors">
              <td class="px-4 py-3">
                <a href="<%= news_path(news) %>" class="text-sm font-medium theme-text-primary hover:text-emerald-600 dark:hover:text-emerald-400"><%= news.title %></a>
              </td>
              <td class="px-4 py-3 text-sm theme-text-secondary">
                <%= news.primary_person.presence || news.primary_team.presence || "—" %>
              </td>
              <td class="px-4 py-3 text-sm theme-text-secondary">
                <%= news.author.presence || "—" %>
              </td>
              <td class="px-4 py-3 text-sm theme-text-secondary">
                <%= news.published_at&.strftime("%b %d, %Y") || news.created_at.strftime("%b %d, %Y") %>
              </td>
              <td class="px-4 py-3 text-right">
                <div class="flex justify-end gap-3">
                  <%= link_to "Restore", news_path(news, news: { stage: "new" }), method: :patch, class: "text-xs text-emerald-600 dark:text-emerald-400 hover:underline font-medium" %>
                  <%= link_to "Delete", news_path(news), method: :delete, data: { confirm: "Permanently delete this news item?" }, class: "text-xs text-red-600 dark:text-red-400 hover:underline font-medium" %>
                </div>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    <% else %>
      <div class="flex items-center justify-center py-16 text-sm theme-text-secondary">
        No archived news items.
      </div>
    <% end %>
  </div>
</div>
