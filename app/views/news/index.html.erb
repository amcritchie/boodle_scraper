<%
  stages = [
    { key: "new",      label: "New",      color: "blue"   },
    { key: "reviewed", label: "Reviewed", color: "yellow" },
    { key: "content",  label: "Content",  color: "purple" },
    { key: "edited",   label: "Edited",   color: "cyan"   },
    { key: "queued",   label: "Queued",   color: "orange" },
    { key: "posted",   label: "Posted",   color: "green"  }
  ]
  active_count = stages.sum { |s| (@news_by_stage[s[:key]] || []).length }
  archived = @news_by_stage["archived"] || []
%>

<%= content_for :head do %>
  <meta name="turbo-visit-control" content="reload">
<% end %>

<div class="max-w-full mx-auto px-4 sm:px-6 lg:px-8 py-8"
     data-controller="news-kanban"
     data-news-kanban-transition-url-value="/api/news/:id/transition"
     data-news-kanban-update-url-value="/api/news/:id"
     data-news-kanban-delete-url-value="/api/news/:id"
     data-news-kanban-news-detail-url-value="/news/:id">

  <div class="bg-gradient-to-r from-emerald-600 to-teal-600 rounded-t-xl p-6 shadow-lg">
    <div class="flex justify-between items-center">
      <div>
        <h1 class="text-2xl font-bold text-white">News</h1>
        <p class="text-emerald-100 text-sm mt-1"><%= active_count %> active items</p>
      </div>
      <div class="flex items-center gap-3">
        <!-- Filter buttons -->
        <div class="flex rounded-lg overflow-hidden border border-white/40 text-sm font-semibold shadow">
          <button onclick="setFilter('all', this)"   id="filter-all"     class="kanban-filter active-filter px-3 py-2 text-white bg-white/30 transition-colors">All</button>
          <button onclick="setFilter('x_post', this)" id="filter-x_post" class="kanban-filter px-3 py-2 text-white bg-white/10 hover:bg-white/20 transition-colors border-l border-white/40">Posts</button>
          <button onclick="setFilter('x_reply', this)" id="filter-x_reply" class="kanban-filter px-3 py-2 text-white bg-white/10 hover:bg-white/20 transition-colors border-l border-white/40">Replies</button>
        </div>
        <!-- Reverse sort toggle -->
        <button onclick="toggleReverse(this)"
                class="bg-white/20 hover:bg-white/30 text-white border border-white/40 px-3 py-2 rounded-lg text-sm font-semibold transition-colors shadow"
                title="Reverse column order">
          ↑↓
        </button>
        <!-- Utility -->
        <button onclick="organizeRanks(this)"
                class="bg-white/20 hover:bg-white/30 text-white border border-white/40 px-3 py-2 rounded-lg text-sm font-semibold transition-colors shadow">
          ↕ Organize
        </button>
        <a href="<%= new_news_path %>" class="bg-white text-emerald-600 hover:bg-emerald-50 px-4 py-2 rounded-lg text-sm font-semibold transition-colors shadow">
          + New News
        </a>
      </div>
    </div>
  </div>

  <% if flash[:notice] %>
    <div class="bg-green-100 dark:bg-green-900 border border-green-400 dark:border-green-700 text-green-700 dark:text-green-200 px-4 py-3" role="alert">
      <%= flash[:notice] %>
    </div>
  <% end %>

  <div class="theme-bg-primary shadow-lg rounded-b-xl border theme-border-primary">
    <!-- Kanban Board -->
    <div class="overflow-x-auto px-4 py-6" data-news-kanban-target="board">
      <div class="flex gap-4 items-stretch">
        <% stages.each do |stage| %>
          <% items = @news_by_stage[stage[:key]] || [] %>
          <div class="flex-1 min-w-[200px] flex flex-col" data-news-kanban-target="column" data-stage="<%= stage[:key] %>">
            <!-- Column Header -->
            <div class="flex items-center justify-between mb-3 px-1">
              <h3 class="text-sm font-semibold theme-text-primary"><%= stage[:label] %></h3>
              <span class="inline-flex items-center justify-center min-w-[1.25rem] h-5 px-1.5 text-xs font-bold rounded-full
                <% case stage[:color]
                   when "blue" %>bg-blue-100 text-blue-700 dark:bg-blue-900 dark:text-blue-200<%
                   when "yellow" %>bg-yellow-100 text-yellow-700 dark:bg-yellow-900 dark:text-yellow-200<%
                   when "purple" %>bg-purple-100 text-purple-700 dark:bg-purple-900 dark:text-purple-200<%
                   when "cyan" %>bg-cyan-100 text-cyan-700 dark:bg-cyan-900 dark:text-cyan-200<%
                   when "green" %>bg-green-100 text-green-700 dark:bg-green-900 dark:text-green-200<%
                   end %>"
                data-news-kanban-target="columnCount" data-stage="<%= stage[:key] %>">
                <%= items.length %>
              </span>
            </div>

            <!-- Drop Zone -->
            <div class="flex-1 min-h-[200px] rounded-lg border-2 border-dashed theme-border-primary p-2 space-y-2 transition-colors"
                 data-news-kanban-target="dropZone"
                 data-stage="<%= stage[:key] %>"
                 data-action="dragover->news-kanban#dragOver dragenter->news-kanban#dragEnter dragleave->news-kanban#dragLeave drop->news-kanban#drop">

              <% first_queued_post  = items.find { |n| n.content_type == 'x_post'  }  if stage[:key] == 'queued' %>
              <% first_queued_reply = items.find { |n| n.content_type == 'x_reply' } if stage[:key] == 'queued' %>
              <% items.each do |news| %>
                <%
                  img_src     = news.selected_image.presence || '/images/news-placeholder.svg'
                  show_image  = %w[reviewed content edited queued posted].include?(news.stage)
                  card_meme   = news.meme_id.present? ? @meme_lookup[news.meme_id] : nil
                  show_opinion = %w[content edited queued posted].include?(news.stage)
                  countdown_type = if stage[:key] == 'queued'
                    if news == first_queued_post then 'x_post'
                    elsif news == first_queued_reply then 'x_reply'
                    end
                  end
                %>
                <div class="relative rounded-lg border theme-border-primary theme-bg-primary shadow-sm cursor-grab active:cursor-grabbing hover:shadow-md transition-all overflow-hidden"
                     draggable="true"
                     data-news-kanban-target="card"
                     data-news-id="<%= news.id %>"
                     data-stage="<%= news.stage %>"
                     data-rank="<%= news.rank %>"
                     data-content-type="<%= news.content_type || 'x_post' %>"
                     <% if countdown_type %>data-countdown-type="<%= countdown_type %>"<% end %>
                     data-action="dragstart->news-kanban#dragStart dragend->news-kanban#dragEnd click->news-kanban#cardClick dragover->news-kanban#cardDragOver drop->news-kanban#cardDrop">

                  <div class="absolute top-1.5 right-1.5 z-10 bg-black/50 text-white text-[10px] font-mono px-1.5 py-0.5 rounded leading-none">#<%= news.id %></div>

                  <% if news.content_type == 'x_reply' %>
                    <div class="absolute top-1.5 left-1.5 z-10 bg-blue-500/70 text-white text-[10px] font-mono px-1.5 py-0.5 rounded leading-none">reply</div>
                  <% end %>
                  <% if news.video_path.present? %>
                    <div class="absolute top-6 left-1.5 z-10 bg-purple-600/80 text-white text-[10px] font-mono px-1.5 py-0.5 rounded leading-none">🎬</div>
                  <% end %>
                  <% if countdown_type %>
                    <div class="absolute bottom-1.5 left-1.5 right-1.5 z-10 bg-emerald-600/90 text-white text-[10px] font-mono px-2 py-1 rounded flex items-center justify-between leading-none"
                         data-countdown-badge="<%= countdown_type %>">
                      <span><%= countdown_type == 'x_reply' ? '💬 reply in' : '📤 post in' %></span>
                      <span data-countdown-timer="<%= countdown_type %>">--:--</span>
                    </div>
                  <% end %>

                  <% if show_image %>
                    <% if card_meme %>
                      <img src="<%= card_meme.path %>" alt="" class="w-full h-24 object-contain bg-gray-900">
                    <% elsif news.selected_image.present? %>
                      <img src="<%= img_src %>" alt="" class="w-full h-24 object-cover">
                    <% else %>
                      <img src="<%= img_src %>" alt="" class="w-full object-cover" style="height:50px;">
                    <% end %>
                  <% end %>

                  <div class="p-3">
                    <!-- Title + Actions -->
                    <div class="flex items-start gap-1 mb-2">
                      <p class="text-sm font-medium theme-text-primary leading-snug line-clamp-2 flex-1">
                        <% if news.stage == 'new' %>
                          <%= news.title %>
                        <% else %>
                          <%= news.title_short.presence || news.title %>
                        <% end %>
                      </p>
                      <div class="flex flex-shrink-0 gap-0.5">
                        <button data-action="click->news-kanban#archiveCard" class="p-0.5 rounded hover:bg-gray-100 dark:hover:bg-gray-700 text-gray-400 hover:text-gray-600 dark:hover:text-gray-300 transition-colors" title="Archive">
                          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 8h14M5 8a2 2 0 110-4h14a2 2 0 110 4M5 8v10a2 2 0 002 2h10a2 2 0 002-2V8m-9 4h4"></path></svg>
                        </button>
                        <button data-action="click->news-kanban#deleteCard" class="p-0.5 rounded hover:bg-red-100 dark:hover:bg-red-900/30 text-gray-400 hover:text-red-600 dark:hover:text-red-400 transition-colors" title="Delete">
                          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
                        </button>
                      </div>
                    </div>

                    <% if news.stage == 'new' %>
                      <!-- Stage 1: new — url, author, published_at, created_at -->
                      <% if news.url.present? %>
                        <a href="<%= news.url %>" target="_blank" class="text-[11px] text-emerald-600 dark:text-emerald-400 truncate block mb-1 hover:underline" data-action="click->news-kanban#stopPropagation"><%= news.url.gsub(/https?:\/\/(www\.)?/, '') %></a>
                      <% end %>
                      <div class="flex justify-between items-center mt-1">
                        <span class="text-[11px] theme-text-secondary"><%= news.author %></span>
                        <span class="text-[11px] theme-text-secondary"><%= (news.published_at || news.created_at).strftime("%b %d, %H:%M") %></span>
                      </div>
                      <p class="text-[11px] theme-text-secondary mt-0.5">Created <%= news.created_at.strftime("%b %d, %H:%M") %></p>

                    <% elsif news.stage == 'reviewed' %>
                      <!-- Stage 2: reviewed — person, team, author, published_at, updated_at -->
                      <div class="flex flex-wrap gap-1 mb-1.5">
                        <% if news.primary_person.present? %>
                          <span class="text-[11px] bg-blue-50 dark:bg-blue-900/30 text-blue-700 dark:text-blue-300 px-1.5 py-0.5 rounded">👤 <%= news.primary_person %></span>
                        <% end %>
                        <% if news.primary_team.present? %>
                          <span class="text-[11px] bg-emerald-50 dark:bg-emerald-900/30 text-emerald-700 dark:text-emerald-300 px-1.5 py-0.5 rounded">🏈 <%= news.primary_team %></span>
                        <% end %>
                      </div>
                      <div class="flex justify-between items-center mt-1">
                        <span class="text-[11px] theme-text-secondary"><%= news.author %></span>
                        <span class="text-[11px] theme-text-secondary"><%= news.published_at&.strftime("%b %d") %></span>
                      </div>
                      <p class="text-[11px] theme-text-secondary mt-0.5">Updated <%= news.updated_at.strftime("%b %d, %H:%M") %></p>

                    <% elsif show_opinion %>
                      <!-- Stages 3-5: content, edited, posted -->
                      <div class="flex items-center gap-1.5 mb-1.5 min-w-0 overflow-hidden">
                        <% if news.feeling_emoji.present? %>
                          <span class="text-base leading-none"><%= news.feeling_emoji %></span>
                        <% end %>
                        <% if news.feeling.present? %>
                          <span class="text-[11px] font-medium theme-text-secondary truncate min-w-0 max-w-[90px]"><%= news.feeling %></span>
                        <% end %>
                      </div>
                      <% if news.opinion.present? %>
                        <p class="text-xs theme-text-secondary line-clamp-2 mb-1.5"><%= news.opinion %></p>
                      <% end %>
                      <div class="flex items-center gap-1.5 mb-1 flex-wrap">
                        <% if news.what_happened.present? %>
                          <span class="text-[11px] bg-purple-50 dark:bg-purple-900/30 text-purple-700 dark:text-purple-300 px-1.5 py-0.5 rounded"><%= news.what_happened %></span>
                        <% end %>
                        <% if news.rank.present? %>
                          <span class="text-[11px] bg-gray-100 dark:bg-gray-800 text-gray-500 dark:text-gray-400 px-1.5 py-0.5 rounded font-mono">#<%= news.rank %></span>
                        <% end %>
                        <% if %w[edited queued posted].include?(news.stage) && news.hashtag.present? %>
                          <span class="text-[11px] theme-text-secondary opacity-70"><%= news.hashtag %></span>
                        <% end %>
                      </div>
                      <% if %w[edited queued posted].include?(news.stage) && (news.primary_team.present? || news.hashtag.present?) %>
                        <div class="flex items-center gap-1 mt-1 mb-0.5">
                          <span class="text-[11px] theme-text-secondary truncate">
                            <% if news.primary_team.present? %>🏈 <%= news.primary_team %><% end %><% if news.primary_team.present? && news.hashtag.present? %> · <% end %><% if news.hashtag.present? %><span class="text-emerald-600 dark:text-emerald-400 font-medium"><%= news.hashtag %></span><% end %>
                          </span>
                        </div>
                      <% end %>
                      <div class="flex justify-between items-center mt-1">
                        <span class="text-[11px] theme-text-secondary"><%= news.published_at&.strftime("%b %d") %></span>
                        <span class="text-[11px] theme-text-secondary">Updated <%= news.updated_at.strftime("%b %d, %H:%M") %></span>
                      </div>
                    <% end %>
                  </div>
                </div>
              <% end %>

              <% if items.empty? %>
                <div class="flex items-center justify-center h-24 text-xs theme-text-secondary">
                  Drop items here
                </div>
              <% end %>
            </div>
          </div>
        <% end %>
      </div>
    </div>
  </div>

  <!-- Archived Link -->
  <% if archived.any? %>
    <div class="mt-4 px-1">
      <a href="<%= archived_news_index_path %>" class="flex items-center gap-2 text-sm font-medium theme-text-secondary hover:theme-text-primary transition-colors">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 8h14M5 8a2 2 0 110-4h14a2 2 0 110 4M5 8v10a2 2 0 002 2h10a2 2 0 002-2V8m-9 4h4"></path></svg>
        Archived
        <span class="inline-flex items-center justify-center min-w-[1.25rem] h-5 px-1.5 text-xs font-bold rounded-full bg-gray-100 text-gray-700 dark:bg-gray-800 dark:text-gray-300"><%= archived.length %></span>
      </a>
    </div>
  <% end %>

  <!-- Toast Container -->
  <div data-news-kanban-target="toastContainer" class="fixed top-4 right-4 z-50 space-y-2"></div>
</div>

<script>
// ── Countdown ────────────────────────────────────────────────────
let countdownSchedule = null;

async function initCountdowns() {
  try {
    const res  = await fetch('/api/news/posting_schedule');
    countdownSchedule = await res.json();
    tickCountdowns();
    setInterval(tickCountdowns, 1000);
  } catch (e) {
    console.warn('Countdown fetch failed:', e);
  }
}

function tickCountdowns() {
  if (!countdownSchedule) return;
  const now = Date.now();

  ['x_post', 'x_reply'].forEach(type => {
    const key     = type === 'x_post' ? 'x_post_next_ms' : 'x_reply_next_ms';
    let   msLeft  = countdownSchedule[key] - now;
    const timers  = document.querySelectorAll(`[data-countdown-timer="${type}"]`);
    if (!timers.length) return;

    if (msLeft <= 0) {
      // Refresh schedule — window passed
      fetch('/api/news/posting_schedule')
        .then(r => r.json())
        .then(d => { countdownSchedule = d; });
      msLeft = 0;
    }

    const totalSec = Math.floor(msLeft / 1000);
    const mins     = Math.floor(totalSec / 60);
    const secs     = totalSec % 60;
    const label    = `${String(mins).padStart(2, '0')}:${String(secs).padStart(2, '0')}`;
    timers.forEach(el => el.textContent = label);
  });
}

document.addEventListener('DOMContentLoaded', initCountdowns);

// ── Filter ────────────────────────────────────────────────────────
const ALWAYS_SHOW_STAGES = ['new', 'reviewed']; // content_type not set yet

let currentFilter = 'all';
let currentReverse = false;

function setFilter(type, btn) {
  currentFilter = type;

  // Update button styles
  document.querySelectorAll('.kanban-filter').forEach(b => {
    b.classList.remove('bg-white/30', 'active-filter');
    b.classList.add('bg-white/10', 'hover:bg-white/20');
  });
  btn.classList.remove('bg-white/10', 'hover:bg-white/20');
  btn.classList.add('bg-white/30', 'active-filter');

  applyFilters();
}

function toggleReverse(btn) {
  currentReverse = !currentReverse;
  btn.textContent = currentReverse ? '↓↑' : '↑↓';
  btn.classList.toggle('bg-white/30', currentReverse);
  btn.classList.toggle('bg-white/20', !currentReverse);
  applyFilters();
}

function applyFilters() {
  document.querySelectorAll('[data-news-kanban-target="dropZone"]').forEach(zone => {
    const stage = zone.dataset.stage;
    const alwaysShow = ALWAYS_SHOW_STAGES.includes(stage);
    const cards = Array.from(zone.querySelectorAll('[data-news-kanban-target="card"]'));

    // Show/hide cards based on filter
    let visibleCount = 0;
    cards.forEach(card => {
      const ct = card.dataset.contentType;
      const show = alwaysShow || currentFilter === 'all' || ct === currentFilter;
      card.style.display = show ? '' : 'none';
      if (show) visibleCount++;
    });

    // Reverse order if toggled — work on visible cards only
    if (currentReverse) {
      const visible = cards.filter(c => c.style.display !== 'none');
      visible.reverse().forEach(c => zone.appendChild(c));
    } else {
      // Restore rank-based order (DESC)
      const all = cards.sort((a, b) => (parseInt(b.dataset.rank) || 0) - (parseInt(a.dataset.rank) || 0));
      all.forEach(c => zone.appendChild(c));
    }

    // Update column count badge
    const badge = document.querySelector(`[data-news-kanban-target="columnCount"][data-stage="${stage}"]`);
    if (badge) badge.textContent = visibleCount;
  });
}

// ── Organize Ranks ────────────────────────────────────────────────
async function organizeRanks(btn) {
  btn.disabled = true;
  btn.textContent = '↕ Organizing…';
  try {
    const res = await fetch('/api/news/organize_ranks', { method: 'POST', headers: { 'Content-Type': 'application/json' } });
    const data = await res.json();
    if (res.ok) {
      btn.textContent = '✓ Done';
      setTimeout(() => window.location.reload(), 600);
    } else {
      btn.textContent = '✕ Error';
      setTimeout(() => { btn.textContent = '↕ Organize Ranks'; btn.disabled = false; }, 2000);
    }
  } catch (e) {
    btn.textContent = '✕ Error';
    setTimeout(() => { btn.textContent = '↕ Organize Ranks'; btn.disabled = false; }, 2000);
  }
}
</script>
