<%
  stages = [
    { key: "new",      label: "New",      color: "blue"   },
    { key: "reviewed", label: "Reviewed", color: "yellow" },
    { key: "content",  label: "Content",  color: "purple" },
    { key: "edited",   label: "Edited",   color: "cyan"   },
    { key: "posted",   label: "Posted",   color: "green"  }
  ]
  active_count = stages.sum { |s| (@news_by_stage[s[:key]] || []).length }
  archived = @news_by_stage["archived"] || []
%>

<div class="max-w-full mx-auto px-4 sm:px-6 lg:px-8 py-8"
     data-controller="news-kanban"
     data-news-kanban-transition-url-value="/api/news/:id/transition"
     data-news-kanban-update-url-value="/api/news/:id"
     data-news-kanban-delete-url-value="/api/news/:id"
     data-news-kanban-news-detail-url-value="/news/:id">

  <div class="bg-gradient-to-r from-emerald-600 to-teal-600 rounded-t-xl p-6 shadow-lg">
    <div class="flex justify-between items-center">
      <div>
        <h1 class="text-2xl font-bold text-white">News</h1>
        <p class="text-emerald-100 text-sm mt-1"><%= active_count %> active items</p>
      </div>
      <a href="<%= new_news_path %>" class="bg-white text-emerald-600 hover:bg-emerald-50 px-4 py-2 rounded-lg text-sm font-semibold transition-colors shadow">
        + New News
      </a>
    </div>
  </div>

  <% if flash[:notice] %>
    <div class="bg-green-100 dark:bg-green-900 border border-green-400 dark:border-green-700 text-green-700 dark:text-green-200 px-4 py-3" role="alert">
      <%= flash[:notice] %>
    </div>
  <% end %>

  <div class="theme-bg-primary shadow-lg rounded-b-xl border theme-border-primary">
    <!-- Kanban Board -->
    <div class="overflow-x-auto px-4 py-6" data-news-kanban-target="board">
      <div class="flex gap-4">
        <% stages.each do |stage| %>
          <% items = @news_by_stage[stage[:key]] || [] %>
          <div class="flex-1 min-w-[200px]" data-news-kanban-target="column" data-stage="<%= stage[:key] %>">
            <!-- Column Header -->
            <div class="flex items-center justify-between mb-3 px-1">
              <h3 class="text-sm font-semibold theme-text-primary"><%= stage[:label] %></h3>
              <span class="inline-flex items-center justify-center min-w-[1.25rem] h-5 px-1.5 text-xs font-bold rounded-full
                <% case stage[:color]
                   when "blue" %>bg-blue-100 text-blue-700 dark:bg-blue-900 dark:text-blue-200<%
                   when "yellow" %>bg-yellow-100 text-yellow-700 dark:bg-yellow-900 dark:text-yellow-200<%
                   when "purple" %>bg-purple-100 text-purple-700 dark:bg-purple-900 dark:text-purple-200<%
                   when "cyan" %>bg-cyan-100 text-cyan-700 dark:bg-cyan-900 dark:text-cyan-200<%
                   when "green" %>bg-green-100 text-green-700 dark:bg-green-900 dark:text-green-200<%
                   end %>"
                data-news-kanban-target="columnCount" data-stage="<%= stage[:key] %>">
                <%= items.length %>
              </span>
            </div>

            <!-- Drop Zone -->
            <div class="min-h-[200px] rounded-lg border-2 border-dashed theme-border-primary p-2 space-y-2 transition-colors"
                 data-news-kanban-target="dropZone"
                 data-stage="<%= stage[:key] %>"
                 data-action="dragover->news-kanban#dragOver dragenter->news-kanban#dragEnter dragleave->news-kanban#dragLeave drop->news-kanban#drop">

              <% items.each do |news| %>
                <div class="rounded-lg border theme-border-primary theme-bg-primary p-3 shadow-sm cursor-grab active:cursor-grabbing hover:shadow-md transition-all"
                     draggable="true"
                     data-news-kanban-target="card"
                     data-news-id="<%= news.id %>"
                     data-stage="<%= news.stage %>"
                     data-action="dragstart->news-kanban#dragStart dragend->news-kanban#dragEnd click->news-kanban#cardClick">

                  <!-- Title + Actions -->
                  <div class="flex items-start gap-1">
                    <p class="text-sm font-medium theme-text-primary leading-snug line-clamp-2 mb-2 flex-1"><%= news.title %></p>
                    <div class="flex flex-shrink-0 gap-0.5">
                      <button data-action="click->news-kanban#archiveCard" class="p-0.5 rounded hover:bg-gray-100 dark:hover:bg-gray-700 text-gray-400 hover:text-gray-600 dark:hover:text-gray-300 transition-colors" title="Archive">
                        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 8h14M5 8a2 2 0 110-4h14a2 2 0 110 4M5 8v10a2 2 0 002 2h10a2 2 0 002-2V8m-9 4h4"></path></svg>
                      </button>
                      <button data-action="click->news-kanban#deleteCard" class="p-0.5 rounded hover:bg-red-100 dark:hover:bg-red-900/30 text-gray-400 hover:text-red-600 dark:hover:text-red-400 transition-colors" title="Delete">
                        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
                      </button>
                    </div>
                  </div>

                  <!-- Person / Team -->
                  <div class="flex items-center gap-1.5 mb-1">
                    <% if news.primary_person.present? %>
                      <span class="text-xs theme-text-secondary"><%= news.primary_person %></span>
                    <% elsif news.primary_team.present? %>
                      <span class="text-xs theme-text-secondary"><%= news.primary_team %></span>
                    <% end %>
                  </div>

                  <!-- Date -->
                  <p class="text-[11px] theme-text-secondary">
                    <%= news.published_at&.strftime("%b %d, %H:%M") || news.created_at.strftime("%b %d, %H:%M") %>
                  </p>
                </div>
              <% end %>

              <% if items.empty? %>
                <div class="flex items-center justify-center h-24 text-xs theme-text-secondary">
                  Drop items here
                </div>
              <% end %>
            </div>
          </div>
        <% end %>
      </div>
    </div>
  </div>

  <!-- Archived Link -->
  <% if archived.any? %>
    <div class="mt-4 px-1">
      <a href="<%= archived_news_index_path %>" class="flex items-center gap-2 text-sm font-medium theme-text-secondary hover:theme-text-primary transition-colors">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 8h14M5 8a2 2 0 110-4h14a2 2 0 110 4M5 8v10a2 2 0 002 2h10a2 2 0 002-2V8m-9 4h4"></path></svg>
        Archived
        <span class="inline-flex items-center justify-center min-w-[1.25rem] h-5 px-1.5 text-xs font-bold rounded-full bg-gray-100 text-gray-700 dark:bg-gray-800 dark:text-gray-300"><%= archived.length %></span>
      </a>
    </div>
  <% end %>

  <!-- Toast Container -->
  <div data-news-kanban-target="toastContainer" class="fixed top-4 right-4 z-50 space-y-2"></div>
</div>
