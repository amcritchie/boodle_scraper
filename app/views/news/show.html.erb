<%
  img_src      = @news.selected_image.presence || '/images/news-placeholder.svg'
  show_image   = %w[reviewed content edited posted].include?(@news.stage)
  show_opinion = %w[content edited posted].include?(@news.stage)
  stage_class  = case @news.stage
    when "new"      then "bg-blue-100 text-blue-800 dark:bg-blue-900 dark:text-blue-200"
    when "reviewed" then "bg-yellow-100 text-yellow-800 dark:bg-yellow-900 dark:text-yellow-200"
    when "content"  then "bg-purple-100 text-purple-800 dark:bg-purple-900 dark:text-purple-200"
    when "edited"   then "bg-cyan-100 text-cyan-800 dark:bg-cyan-900 dark:text-cyan-200"
    when "posted"   then "bg-green-100 text-green-800 dark:bg-green-900 dark:text-green-200"
    else                 "bg-gray-100 text-gray-800 dark:bg-gray-700 dark:text-gray-200"
    end
%>

<div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
  <div class="bg-gradient-to-r from-emerald-600 to-teal-600 rounded-t-xl p-6 shadow-lg">
    <div class="flex justify-between items-center">
      <div>
        <h1 class="text-2xl font-bold text-white">
          <% if @news.stage == 'new' %>
            <%= @news.title %>
          <% else %>
            <%= @news.title_short.presence || @news.title %>
          <% end %>
        </h1>
        <span class="inline-flex px-2 py-1 text-xs font-semibold rounded-full mt-2 <%= stage_class %>"><%= @news.stage %></span>
      </div>
      <a href="<%= edit_news_path(@news) %>" class="bg-white text-emerald-600 hover:bg-emerald-50 px-4 py-2 rounded-lg text-sm font-semibold transition-colors shadow">
        Edit
      </a>
    </div>
  </div>

  <div class="theme-bg-primary shadow-lg rounded-b-xl p-6 border border-t-0 theme-border-primary">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">

      <!-- Main Content -->
      <div class="md:col-span-2 space-y-6">

        <% if @news.stage == 'new' %>
          <%# ── Stage 1: new ─────────────────────────────────── %>

          <div>
            <h3 class="text-sm font-medium theme-text-secondary uppercase mb-2">Full Title</h3>
            <p class="text-sm theme-text-primary"><%= @news.title %></p>
          </div>

          <% if @news.url.present? %>
            <div>
              <h3 class="text-sm font-medium theme-text-secondary uppercase mb-2">URL</h3>
              <a href="<%= @news.url %>" target="_blank" class="text-sm text-emerald-600 dark:text-emerald-400 hover:underline break-all"><%= @news.url %></a>
            </div>
          <% end %>

        <% elsif @news.stage == 'reviewed' %>
          <%# ── Stage 2: reviewed ────────────────────────────── %>

          <% if show_image %>
            <img src="<%= img_src %>" alt="" class="rounded-lg w-full max-h-64 object-cover">
          <% end %>

          <% if @news.summary.present? %>
            <div>
              <h3 class="text-sm font-medium theme-text-secondary uppercase mb-2">Summary</h3>
              <p class="text-sm theme-text-primary"><%= @news.summary %></p>
            </div>
          <% end %>

        <% elsif show_opinion %>
          <%# ── Stages 3–5: content / edited / posted ─────────── %>

          <% if show_image %>
            <img src="<%= img_src %>" alt="" class="rounded-lg w-full max-h-64 object-cover">
          <% end %>

          <% if @news.opinion.present? %>
            <div>
              <h3 class="text-sm font-medium theme-text-secondary uppercase mb-2">Opinion</h3>
              <p class="text-sm theme-text-primary"><%= @news.opinion %></p>
            </div>
          <% end %>

          <% if @news.post_body.present? %>
            <div>
              <h3 class="text-sm font-medium theme-text-secondary uppercase mb-2">Post Body</h3>
              <pre class="text-xs theme-bg-tertiary rounded-lg p-3 overflow-x-auto theme-text-primary"><%= JSON.pretty_generate(@news.post_body) %></pre>
            </div>
          <% end %>
        <% end %>

      </div>

      <!-- Sidebar -->
      <div class="space-y-4">
        <div class="theme-bg-tertiary rounded-lg p-4 space-y-3">

          <% if @news.stage == 'new' %>
            <%# Stage 1 sidebar: author, published_at, created_at %>
            <% if @news.author.present? %>
              <div>
                <p class="text-xs font-medium theme-text-secondary uppercase">Author</p>
                <p class="text-sm theme-text-primary mt-1"><%= @news.author %></p>
              </div>
            <% end %>
            <div>
              <p class="text-xs font-medium theme-text-secondary uppercase">Published</p>
              <p class="text-sm theme-text-primary mt-1"><%= @news.published_at&.strftime("%b %d, %Y %H:%M") || "—" %></p>
            </div>
            <div>
              <p class="text-xs font-medium theme-text-secondary uppercase">Created</p>
              <p class="text-sm theme-text-primary mt-1"><%= @news.created_at.strftime("%b %d, %Y %H:%M") %></p>
            </div>

          <% elsif @news.stage == 'reviewed' %>
            <%# Stage 2 sidebar: person, team, author, published_at, updated_at %>
            <% if @news.primary_person.present? %>
              <div>
                <p class="text-xs font-medium theme-text-secondary uppercase">Primary Person</p>
                <p class="text-sm theme-text-primary mt-1"><%= @news.primary_person %></p>
              </div>
            <% end %>
            <% if @news.primary_team.present? %>
              <div>
                <p class="text-xs font-medium theme-text-secondary uppercase">Primary Team</p>
                <p class="text-sm theme-text-primary mt-1"><%= @news.primary_team %></p>
              </div>
            <% end %>
            <% if @news.author.present? %>
              <div>
                <p class="text-xs font-medium theme-text-secondary uppercase">Author</p>
                <p class="text-sm theme-text-primary mt-1"><%= @news.author %></p>
              </div>
            <% end %>
            <div>
              <p class="text-xs font-medium theme-text-secondary uppercase">Published</p>
              <p class="text-sm theme-text-primary mt-1"><%= @news.published_at&.strftime("%b %d, %Y %H:%M") || "—" %></p>
            </div>
            <div>
              <p class="text-xs font-medium theme-text-secondary uppercase">Updated</p>
              <p class="text-sm theme-text-primary mt-1"><%= @news.updated_at.strftime("%b %d, %Y %H:%M") %></p>
            </div>

          <% elsif show_opinion %>
            <%# Stages 3-5 sidebar: published_at, updated_at %>
            <div>
              <p class="text-xs font-medium theme-text-secondary uppercase">Published</p>
              <p class="text-sm theme-text-primary mt-1"><%= @news.published_at&.strftime("%b %d, %Y %H:%M") || "—" %></p>
            </div>
            <div>
              <p class="text-xs font-medium theme-text-secondary uppercase">Updated</p>
              <p class="text-sm theme-text-primary mt-1"><%= @news.updated_at.strftime("%b %d, %Y %H:%M") %></p>
            </div>
          <% end %>

        </div>

        <div class="flex flex-wrap gap-2">
          <a href="<%= news_index_path %>" class="theme-text-secondary hover:theme-text-primary text-sm font-medium">← Back to Board</a>
        </div>

        <% unless @news.stage == "archived" %>
          <div>
            <%= link_to "Archive", news_path(@news, news: { stage: "archived" }), method: :patch, class: "inline-flex w-full justify-center bg-gray-500 hover:bg-gray-600 text-white px-4 py-2 rounded-lg text-sm font-medium transition-colors", data: { confirm: "Archive this news item?" } %>
          </div>
        <% end %>

        <div>
          <%= link_to "Delete", news_path(@news), method: :delete, class: "inline-flex w-full justify-center bg-red-500 hover:bg-red-600 text-white px-4 py-2 rounded-lg text-sm font-medium transition-colors", data: { confirm: "Are you sure you want to delete this news item?" } %>
        </div>
      </div>

    </div>
  </div>
</div>
