<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
  <div class="bg-gradient-to-r from-emerald-600 to-teal-600 rounded-t-xl p-6 shadow-lg">
    <div class="flex justify-between items-center">
      <div>
        <h1 class="text-2xl font-bold text-white">Agents</h1>
        <p class="text-emerald-100 text-sm mt-1"><%= @agents.count %> agents</p>
      </div>
      <a href="<%= agents_dashboard_new_path %>" class="bg-white text-emerald-600 hover:bg-emerald-50 px-4 py-2 rounded-lg text-sm font-semibold transition-colors shadow">
        + New Agent
      </a>
    </div>
  </div>

  <% if flash[:notice] %>
    <div class="bg-green-100 dark:bg-green-900 border border-green-400 dark:border-green-700 text-green-700 dark:text-green-200 px-4 py-3" role="alert">
      <%= flash[:notice] %>
    </div>
  <% end %>

  <div class="theme-bg-primary shadow-lg rounded-b-xl overflow-hidden border theme-border-primary">
    <%= render "agents_dashboard/subnav" %>

    <div class="overflow-x-auto">
      <table class="min-w-full divide-y theme-border-primary">
        <thead class="theme-bg-tertiary">
          <tr>
            <th class="px-4 py-3 text-left text-xs font-medium theme-text-secondary uppercase tracking-wider">Name</th>
            <th class="px-4 py-3 text-left text-xs font-medium theme-text-secondary uppercase tracking-wider">Status</th>
            <th class="px-4 py-3 text-left text-xs font-medium theme-text-secondary uppercase tracking-wider">Type</th>
            <th class="px-4 py-3 text-left text-xs font-medium theme-text-secondary uppercase tracking-wider">Model</th>
            <th class="px-4 py-3 text-left text-xs font-medium theme-text-secondary uppercase tracking-wider">Skills</th>
            <th class="px-4 py-3 text-center text-xs font-medium theme-text-secondary uppercase tracking-wider">Tasks</th>
            <th class="px-4 py-3 text-left text-xs font-medium theme-text-secondary uppercase tracking-wider">Last Active</th>
            <th class="px-4 py-3 text-right text-xs font-medium theme-text-secondary uppercase tracking-wider">Actions</th>
          </tr>
        </thead>
        <tbody class="divide-y theme-border-primary">
          <% @agents.each do |agent| %>
            <tr class="hover:theme-bg-tertiary transition-colors">
              <td class="px-4 py-3 text-sm font-medium">
                <a href="<%= agents_dashboard_show_path(agent.slug) %>" class="flex items-center gap-2 text-emerald-600 dark:text-emerald-400 hover:underline">
                  <% if agent.avatar_url.present? %>
                    <img src="<%= agent.avatar_url %>" class="w-8 h-8 rounded-full" alt="<%= agent.name %>">
                  <% else %>
                    <div class="w-8 h-8 rounded-full bg-emerald-100 dark:bg-emerald-900 flex items-center justify-center flex-shrink-0">
                      <span class="text-emerald-700 dark:text-emerald-300 font-bold text-xs"><%= agent.name[0..1].upcase %></span>
                    </div>
                  <% end %>
                  <%= agent.name %>
                </a>
              </td>
              <td class="px-4 py-3 text-sm">
                <% status_class = case agent.status
                   when "active" then "bg-green-100 text-green-800 dark:bg-green-900 dark:text-green-200"
                   when "paused" then "bg-yellow-100 text-yellow-800 dark:bg-yellow-900 dark:text-yellow-200"
                   else "bg-gray-100 text-gray-800 dark:bg-gray-700 dark:text-gray-200"
                   end %>
                <span class="inline-flex px-2 py-1 text-xs font-semibold rounded-full <%= status_class %>"><%= agent.status %></span>
              </td>
              <td class="px-4 py-3 text-sm theme-text-secondary"><%= agent.agent_type %></td>
              <td class="px-4 py-3 text-sm" data-controller="model-picker" data-model-picker-slug-value="<%= agent.slug %>">
                <% current_model = agent.config&.dig("model") || "—" %>
                <div data-model-picker-target="display" class="flex items-center gap-1 cursor-pointer group" data-action="click->model-picker#showPicker">
                  <span class="font-mono text-xs theme-text-primary group-hover:text-emerald-500 transition-colors"><%= current_model.split("/").last %></span>
                  <svg class="w-3 h-3 theme-text-secondary group-hover:text-emerald-500 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z" /></svg>
                </div>
                <div data-model-picker-target="picker" class="hidden mt-1">
                  <select data-action="change->model-picker#updateModel" class="w-full rounded border theme-border-primary theme-bg-primary theme-text-primary px-2 py-1 text-xs focus:ring-1 focus:ring-emerald-500">
                    <option value="">— custom —</option>
                    <optgroup label="Anthropic">
                      <option value="anthropic/claude-sonnet-4-6" <%= "selected" if current_model == "anthropic/claude-sonnet-4-6" %>>claude-sonnet-4-6</option>
                      <option value="anthropic/claude-haiku-4-5" <%= "selected" if current_model == "anthropic/claude-haiku-4-5" %>>claude-haiku-4-5</option>
                      <option value="anthropic/claude-opus-4-5" <%= "selected" if current_model == "anthropic/claude-opus-4-5" %>>claude-opus-4-5</option>
                    </optgroup>
                    <optgroup label="OpenAI">
                      <option value="openai/gpt-4o" <%= "selected" if current_model == "openai/gpt-4o" %>>gpt-4o</option>
                      <option value="openai/gpt-4o-mini" <%= "selected" if current_model == "openai/gpt-4o-mini" %>>gpt-4o-mini</option>
                    </optgroup>
                    <optgroup label="Google">
                      <option value="google/gemini-3-flash-preview" <%= "selected" if current_model == "google/gemini-3-flash-preview" %>>gemini-3-flash-preview</option>
                      <option value="google/gemini-2.0-flash" <%= "selected" if current_model == "google/gemini-2.0-flash" %>>gemini-2.0-flash</option>
                    </optgroup>
                    <optgroup label="xAI">
                      <option value="xai/grok-3" <%= "selected" if current_model == "xai/grok-3" %>>grok-3</option>
                    </optgroup>
                  </select>
                  <div class="flex gap-1 mt-1">
                    <input type="text" data-model-picker-target="customInput" placeholder="or type model…" class="hidden w-full rounded border theme-border-primary theme-bg-primary theme-text-primary px-2 py-1 text-xs focus:ring-1 focus:ring-emerald-500" />
                  </div>
                  <div data-model-picker-target="status" class="text-xs mt-1 hidden"></div>
                </div>
              </td>
              <td class="px-4 py-3 text-sm theme-text-secondary"><%= agent.agent_skills.count %></td>
              <td class="px-4 py-3 text-sm theme-text-secondary text-center"><%= agent.agent_tasks.count %></td>
              <td class="px-4 py-3 text-sm theme-text-secondary"><%= agent.last_active_at&.strftime("%b %d, %H:%M") || "—" %></td>
              <td class="px-4 py-3 text-right text-sm whitespace-nowrap">
                <a href="<%= agents_dashboard_edit_path(agent.slug) %>" class="text-emerald-600 dark:text-emerald-400 hover:text-emerald-900 font-medium mr-3">Edit</a>
                <%= button_to "Delete", agents_dashboard_destroy_path(agent.slug), method: :delete, data: { turbo_confirm: "Delete agent #{agent.name}?" }, class: "text-red-600 dark:text-red-400 hover:text-red-900 font-medium", form: { class: "inline" } %>
              </td>
            </tr>
          <% end %>
          <% if @agents.empty? %>
            <tr>
              <td colspan="7" class="px-4 py-8 text-center theme-text-secondary text-sm">
                No agents yet. <a href="<%= agents_dashboard_new_path %>" class="text-emerald-600 dark:text-emerald-400 hover:underline">Create one</a>.
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>
</div>
