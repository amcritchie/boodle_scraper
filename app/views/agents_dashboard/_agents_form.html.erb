<%= form_with(model: agent, url: agent.new_record? ? agents_dashboard_create_path : agents_dashboard_update_path(agent.slug), method: agent.new_record? ? :post : :patch, local: true, class: "space-y-6") do |f| %>
  <% if agent.errors.any? %>
    <div class="bg-red-100 dark:bg-red-900 border border-red-400 dark:border-red-700 text-red-700 dark:text-red-200 px-4 py-3 rounded">
      <h3 class="font-medium"><%= pluralize(agent.errors.count, "error") %> prohibited this agent from being saved:</h3>
      <ul class="mt-2 list-disc list-inside text-sm">
        <% agent.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
    <div>
      <%= f.label :name, class: "block text-sm font-medium theme-text-primary mb-1" %>
      <%= f.text_field :name, class: "w-full rounded-lg border theme-border-primary theme-bg-primary theme-text-primary px-3 py-2 text-sm focus:ring-2 focus:ring-emerald-500 focus:border-emerald-500" %>
    </div>

    <div>
      <%= f.label :slug, class: "block text-sm font-medium theme-text-primary mb-1" %>
      <%= f.text_field :slug, class: "w-full rounded-lg border theme-border-primary theme-bg-primary theme-text-primary px-3 py-2 text-sm focus:ring-2 focus:ring-emerald-500 focus:border-emerald-500" %>
    </div>

    <div>
      <%= f.label :status, class: "block text-sm font-medium theme-text-primary mb-1" %>
      <%= f.select :status, options_for_select([["Active", "active"], ["Paused", "paused"], ["Inactive", "inactive"]], agent.status), {}, class: "w-full rounded-lg border theme-border-primary theme-bg-primary theme-text-primary px-3 py-2 text-sm focus:ring-2 focus:ring-emerald-500 focus:border-emerald-500" %>
    </div>

    <div>
      <%= f.label :agent_type, "Type", class: "block text-sm font-medium theme-text-primary mb-1" %>
      <%= f.text_field :agent_type, class: "w-full rounded-lg border theme-border-primary theme-bg-primary theme-text-primary px-3 py-2 text-sm focus:ring-2 focus:ring-emerald-500 focus:border-emerald-500", placeholder: "e.g. content, analytics" %>
    </div>

    <div class="md:col-span-2">
      <%= f.label :description, class: "block text-sm font-medium theme-text-primary mb-1" %>
      <%= f.text_area :description, rows: 3, class: "w-full rounded-lg border theme-border-primary theme-bg-primary theme-text-primary px-3 py-2 text-sm focus:ring-2 focus:ring-emerald-500 focus:border-emerald-500" %>
    </div>

    <div>
      <%= f.label :avatar_url, "Avatar URL", class: "block text-sm font-medium theme-text-primary mb-1" %>
      <div class="flex items-center gap-3">
        <% if agent.avatar_url.present? %>
          <img src="<%= agent.avatar_url %>" class="w-10 h-10 rounded-full flex-shrink-0" alt="Avatar preview">
        <% else %>
          <div class="w-10 h-10 rounded-full bg-emerald-100 dark:bg-emerald-900 flex items-center justify-center flex-shrink-0">
            <span class="text-emerald-700 dark:text-emerald-300 font-bold text-sm"><%= agent.name.present? ? agent.name[0..1].upcase : "??" %></span>
          </div>
        <% end %>
        <%= f.url_field :avatar_url, class: "w-full rounded-lg border theme-border-primary theme-bg-primary theme-text-primary px-3 py-2 text-sm focus:ring-2 focus:ring-emerald-500 focus:border-emerald-500" %>
      </div>
    </div>

    <div class="md:col-span-2">
      <%= f.label :config, "Config (JSON)", class: "block text-sm font-medium theme-text-primary mb-1" %>
      <%= f.text_area :config, value: agent.config.present? ? JSON.pretty_generate(agent.config) : "{}", rows: 4, class: "w-full rounded-lg border theme-border-primary theme-bg-primary theme-text-primary px-3 py-2 text-sm font-mono focus:ring-2 focus:ring-emerald-500 focus:border-emerald-500" %>
      <p class="mt-1 text-xs theme-text-secondary">Enter valid JSON for agent configuration</p>
    </div>
  </div>

  <div class="flex items-center space-x-4 pt-4">
    <%= f.submit class: "bg-emerald-600 hover:bg-emerald-700 text-white px-6 py-2 rounded-lg text-sm font-semibold transition-colors shadow cursor-pointer" %>
    <a href="<%= agents_dashboard_list_path %>" class="theme-text-secondary hover:theme-text-primary text-sm font-medium">Cancel</a>
  </div>
<% end %>
