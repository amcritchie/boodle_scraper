<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
  <div class="bg-gradient-to-r from-emerald-600 to-teal-600 rounded-t-xl p-6 shadow-lg">
    <h1 class="text-2xl font-bold text-white">Skills</h1>
    <p class="text-emerald-100 text-sm mt-1"><%= @skills.count %> skills defined</p>
  </div>

  <div class="theme-bg-primary shadow-lg rounded-b-xl p-6 border border-t-0 theme-border-primary">
    <%= render "agents_dashboard/subnav" %>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
      <% @skills.each do |skill| %>
        <div class="theme-bg-tertiary rounded-lg p-4 border theme-border-primary">
          <div class="flex justify-between items-start mb-2">
            <h3 class="font-semibold theme-text-primary text-sm"><%= skill.name %></h3>
            <% if skill.category.present? %>
              <span class="inline-flex px-2 py-0.5 text-xs rounded-full bg-emerald-100 text-emerald-800 dark:bg-emerald-900 dark:text-emerald-200"><%= skill.category %></span>
            <% end %>
          </div>
          <% if skill.description.present? %>
            <p class="text-xs theme-text-secondary mb-3"><%= skill.description %></p>
          <% end %>
          <div>
            <p class="text-xs font-medium theme-text-secondary uppercase mb-1">Assigned Agents</p>
            <div class="flex flex-wrap gap-1">
              <% skill.agents.each do |agent| %>
                <a href="<%= agents_dashboard_show_path(agent.slug) %>" class="inline-flex px-2 py-0.5 text-xs rounded-full bg-blue-100 text-blue-800 dark:bg-blue-900 dark:text-blue-200 hover:underline"><%= agent.name %></a>
              <% end %>
              <% if skill.agents.empty? %>
                <span class="text-xs theme-text-secondary">None</span>
              <% end %>
            </div>
          </div>
        </div>
      <% end %>

      <% if @skills.empty? %>
        <div class="md:col-span-3 text-center theme-text-secondary text-sm py-8">
          No skills defined yet.
        </div>
      <% end %>
    </div>
  </div>
</div>
