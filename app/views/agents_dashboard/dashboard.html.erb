<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
  <!-- Header -->
  <div class="bg-gradient-to-r from-emerald-600 to-teal-600 rounded-t-xl p-6 shadow-lg">
    <h1 class="text-2xl font-bold text-white">Agent Dashboard</h1>
    <p class="text-emerald-100 text-sm mt-1">Manage your AI agents, tasks, and workflows</p>
  </div>

  <div class="theme-bg-primary shadow-lg rounded-b-xl p-6 border border-t-0 theme-border-primary">
    <%= render "agents_dashboard/subnav" %>

    <!-- Stat Cards -->
    <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-8">
      <div class="theme-bg-tertiary rounded-lg p-4">
        <p class="text-xs font-medium theme-text-secondary uppercase">Total Agents</p>
        <p class="text-2xl font-bold theme-text-primary mt-1"><%= @agents.count %></p>
      </div>
      <div class="theme-bg-tertiary rounded-lg p-4">
        <p class="text-xs font-medium theme-text-secondary uppercase">Active Tasks</p>
        <p class="text-2xl font-bold text-purple-600 dark:text-purple-400 mt-1"><%= @task_counts["in_progress"] || 0 %></p>
      </div>
      <div class="theme-bg-tertiary rounded-lg p-4">
        <p class="text-xs font-medium theme-text-secondary uppercase">Queued</p>
        <p class="text-2xl font-bold text-yellow-600 dark:text-yellow-400 mt-1"><%= @task_counts["queued"] || 0 %></p>
      </div>
      <div class="theme-bg-tertiary rounded-lg p-4">
        <p class="text-xs font-medium theme-text-secondary uppercase">Unassigned</p>
        <p class="text-2xl font-bold text-blue-600 dark:text-blue-400 mt-1"><%= @unassigned_count %></p>
      </div>
    </div>

    <!-- Agent Cards + Activity Feed -->
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
      <!-- Agent Cards -->
      <div class="lg:col-span-2">
        <div class="flex justify-between items-center mb-4">
          <h2 class="text-lg font-semibold theme-text-primary">Agents</h2>
          <a href="<%= agents_dashboard_new_path %>" class="text-emerald-600 dark:text-emerald-400 hover:underline text-sm font-medium">+ New Agent</a>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          <% @agents.each do |agent| %>
            <a href="<%= agents_dashboard_show_path(agent.slug) %>" class="block theme-bg-tertiary rounded-lg p-4 hover:shadow-md transition-shadow border theme-border-primary">
              <div class="flex items-center space-x-3 mb-3">
                <% if agent.avatar_url.present? %>
                  <img src="<%= agent.avatar_url %>" class="w-10 h-10 rounded-full" alt="<%= agent.name %>">
                <% else %>
                  <div class="w-10 h-10 rounded-full bg-emerald-100 dark:bg-emerald-900 flex items-center justify-center">
                    <span class="text-emerald-600 dark:text-emerald-400 font-bold text-sm"><%= agent.name[0..1].upcase %></span>
                  </div>
                <% end %>
                <div>
                  <h3 class="font-semibold theme-text-primary"><%= agent.name %></h3>
                  <p class="text-xs theme-text-secondary"><%= agent.agent_type %></p>
                </div>
                <% status_class = case agent.status
                   when "active" then "bg-green-100 text-green-800 dark:bg-green-900 dark:text-green-200"
                   when "paused" then "bg-yellow-100 text-yellow-800 dark:bg-yellow-900 dark:text-yellow-200"
                   else "bg-gray-100 text-gray-800 dark:bg-gray-700 dark:text-gray-200"
                   end %>
                <span class="ml-auto inline-flex px-2 py-0.5 text-xs font-semibold rounded-full <%= status_class %>"><%= agent.status %></span>
              </div>
              <p class="text-sm theme-text-secondary line-clamp-2"><%= agent.description %></p>
              <div class="flex space-x-4 mt-3 text-xs theme-text-secondary">
                <span><%= agent.agent_tasks.count %> tasks</span>
                <span><%= agent.agent_skills.count %> skills</span>
              </div>
            </a>
          <% end %>
        </div>
      </div>

      <!-- Recent Activity -->
      <div>
        <div class="flex justify-between items-center mb-4">
          <h2 class="text-lg font-semibold theme-text-primary">Recent Activity</h2>
          <a href="<%= agents_dashboard_activity_path %>" class="text-emerald-600 dark:text-emerald-400 hover:underline text-sm font-medium">View all</a>
        </div>
        <div class="space-y-3">
          <% @recent_activities.each do |activity| %>
            <div class="flex items-start space-x-3">
              <% dot_class = case activity.activity_type
                 when "task_completed" then "bg-green-500"
                 when "task_failed" then "bg-red-500"
                 when "task_started" then "bg-purple-500"
                 when "skill_used" then "bg-blue-500"
                 when "error" then "bg-red-500"
                 when "status_change" then "bg-yellow-500"
                 else "bg-gray-400"
                 end %>
              <div class="w-2 h-2 rounded-full mt-1.5 flex-shrink-0 <%= dot_class %>"></div>
              <div class="min-w-0">
                <p class="text-sm theme-text-primary truncate"><%= activity.description %></p>
                <p class="text-xs theme-text-secondary"><%= activity.agent_slug %> &middot; <%= time_ago_in_words(activity.created_at) %> ago</p>
              </div>
            </div>
          <% end %>
          <% if @recent_activities.empty? %>
            <p class="text-sm theme-text-secondary">No recent activity.</p>
          <% end %>
        </div>
      </div>
    </div>
  </div>
</div>
