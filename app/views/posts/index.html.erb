<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
  <!-- Header -->
  <div class="bg-gradient-to-r from-amber-600 to-orange-600 rounded-t-xl p-6 shadow-lg">
    <div class="flex justify-between items-center">
      <div>
        <h1 class="text-2xl font-bold text-white">Posts</h1>
        <p class="text-amber-100 text-sm mt-1"><%= @posts.count %> posts</p>
      </div>
      <a href="<%= new_post_path %>" class="bg-white text-amber-600 hover:bg-amber-50 px-4 py-2 rounded-lg text-sm font-semibold transition-colors shadow">
        + New Post
      </a>
    </div>
  </div>

  <% if flash[:notice] %>
    <div class="bg-green-100 dark:bg-green-900 border border-green-400 dark:border-green-700 text-green-700 dark:text-green-200 px-4 py-3 rounded-b-none" role="alert">
      <%= flash[:notice] %>
    </div>
  <% end %>

  <!-- Table -->
  <div class="theme-bg-primary shadow-lg rounded-b-xl overflow-hidden border theme-border-primary">
    <div class="overflow-x-auto">
      <table class="min-w-full divide-y theme-border-primary">
        <thead class="theme-bg-tertiary">
          <tr>
            <th class="px-4 py-3 text-left text-xs font-medium theme-text-secondary uppercase tracking-wider">Title</th>
            <th class="px-4 py-3 text-left text-xs font-medium theme-text-secondary uppercase tracking-wider">Stage</th>
            <th class="px-4 py-3 text-center text-xs font-medium theme-text-secondary uppercase tracking-wider">Impressions</th>
            <th class="px-4 py-3 text-center text-xs font-medium theme-text-secondary uppercase tracking-wider">Likes</th>
            <th class="px-4 py-3 text-left text-xs font-medium theme-text-secondary uppercase tracking-wider">Image</th>
            <th class="px-4 py-3 text-left text-xs font-medium theme-text-secondary uppercase tracking-wider">Approved</th>
            <th class="px-4 py-3 text-left text-xs font-medium theme-text-secondary uppercase tracking-wider">Posted</th>
            <th class="px-4 py-3 text-right text-xs font-medium theme-text-secondary uppercase tracking-wider">Actions</th>
          </tr>
        </thead>
        <tbody class="divide-y theme-border-primary">
          <% @posts.each do |post| %>
            <tr class="hover:theme-bg-tertiary transition-colors">
              <td class="px-4 py-3 text-sm theme-text-primary font-medium max-w-xs truncate"><%= post.title %></td>
              <td class="px-4 py-3 text-sm">
                <% if post.stage.present? %>
                  <% stage_class = case post.stage
                     when 'draft' then 'bg-gray-100 text-gray-800 dark:bg-gray-700 dark:text-gray-200'
                     when 'images' then 'bg-blue-100 text-blue-800 dark:bg-blue-900 dark:text-blue-200'
                     when 'approved' then 'bg-green-100 text-green-800 dark:bg-green-900 dark:text-green-200'
                     when 'posted' then 'bg-amber-100 text-amber-800 dark:bg-amber-900 dark:text-amber-200'
                     else 'bg-gray-100 text-gray-800 dark:bg-gray-700 dark:text-gray-200'
                     end %>
                  <span class="inline-flex px-2 py-1 text-xs font-semibold rounded-full <%= stage_class %>"><%= post.stage %></span>
                <% end %>
              </td>
              <td class="px-4 py-3 text-sm theme-text-secondary text-center"><%= post.impressions %></td>
              <td class="px-4 py-3 text-sm theme-text-secondary text-center"><%= post.likes %></td>
              <td class="px-4 py-3 text-sm">
                <% if post.image_url.present? %>
                  <a href="<%= post.image_url %>" target="_blank" class="text-amber-600 dark:text-amber-400 hover:underline text-xs">View</a>
                <% else %>
                  <span class="theme-text-secondary text-xs">—</span>
                <% end %>
              </td>
              <td class="px-4 py-3 text-sm theme-text-secondary"><%= post.approved_at&.strftime("%b %d") %></td>
              <td class="px-4 py-3 text-sm theme-text-secondary"><%= post.posted_at&.strftime("%b %d") %></td>
              <td class="px-4 py-3 text-right text-sm whitespace-nowrap">
                <a href="<%= edit_post_path(post) %>" class="text-amber-600 dark:text-amber-400 hover:text-amber-900 dark:hover:text-amber-300 font-medium mr-3">Edit</a>
                <%= button_to "Delete", post_path(post), method: :delete, data: { turbo_confirm: "Are you sure you want to delete this post?" }, class: "text-red-600 dark:text-red-400 hover:text-red-900 dark:hover:text-red-300 font-medium", form: { class: "inline" } %>
              </td>
            </tr>
          <% end %>

          <% if @posts.empty? %>
            <tr>
              <td colspan="8" class="px-4 py-8 text-center theme-text-secondary text-sm">
                No posts yet. <a href="<%= new_post_path %>" class="text-amber-600 dark:text-amber-400 hover:underline">Create one</a>.
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>
</div>
